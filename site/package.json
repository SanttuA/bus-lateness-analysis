{
  "name": "@bus-lateness/public-report",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "format": "prettier --ignore-path ../.prettierignore --write . ../README.md ../package.json ../pnpm-workspace.yaml ../.github/workflows/pages.yml",
    "format:check": "prettier --ignore-path ../.prettierignore --check . ../README.md ../package.json ../pnpm-workspace.yaml ../.github/workflows/pages.yml",
    "lint": "oxlint -c oxlint.json --deny-warnings --report-unused-disable-directives",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "test:a11y": "playwright test --grep @a11y",
    "social:preview": "node scripts/capture-social-preview.mjs"
  },
  "dependencies": {
    "@observablehq/plot": "0.6.17",
    "@tanstack/react-router": "1.170.18",
    "leaflet": "1.9.4",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tanstack/router-plugin": "1.168.23",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/leaflet": "1.9.21",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "29.1.1",
    "oxlint": "1.75.0",
    "prettier": "3.9.6",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
